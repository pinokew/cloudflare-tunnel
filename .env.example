# Версія образу cloudflared 
CLOUDFLARE_TUNNEL_VERSION=2026.2.0

# Токен тунелю — отримуєш у Cloudflare Zero Trust Dashboard:
# Zero Trust → Networks → Tunnels → <твій тунель> → Configure → Install connector
TUNNEL_TOKEN=eyJhIjoiYmI0M2JkZmNhYWNkMWIwMmFkOWMyZGRiYjU0Njg4NGEiLCJ0IjoiZWZmMGFjNmItNTRlMS00YmM3LWJmZTYtMmNhN2U1NWFiOTkxIiwicyI6Ik1tWmhPVFptWlRBdE5tWTBaaTAwT1ROa0xXRXlPVGd0Tm1FNVl6azBOMlZpTmpsaCJ9

# =================================================================
# МЕРЕЖА (proxy-net)
# Ця мережа створюється DSpace-stack (docker-compose.yml там).
# Переконайся, що DSpace-stack запущено ПЕРЕД цим стеком.
